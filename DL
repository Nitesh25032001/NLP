def sigmoid(a):
  return 1/(1+np.exp(-a))
def relu(a):
  return np.maximum(0, a)
def tanh(a):
  return np.tanh(a)
def leaky_relu(a,alpha = 0.01):
  return np.where(a>0,a,alpha * a)
def softplus(a):
  return np.log(1+np.exp(a))
def softmax(a):
  exp_a = np.exp(a-np.max(a))
  return exp_a/np.sum(exp_a)
