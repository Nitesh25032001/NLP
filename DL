class perceptron_stack(nn.Module):
  def __init__(self):
    super().__init__()
    self.lay1 = nn.Linear(4,3,bias = True)
    self.lay2 = nn.Linear(3,2,bias = True)
    self.act1 = nn.Sigmoid()
    self.act2 = nn.Softmax(dim = -1)
  def forward(self,x):
    out = x
    out = self.lay1(out)
    out = self.act1(out)
    out = self.lay2(out)
    out = self.act2(out)
    return out
fn = perceptron_stack()
weight_array = np.array([[0.6,0.3,0.8],[0.2,0.2,0.1],[0.8,0.8,0.3],[0.1,0.3,0.6]]).T
bias_array = np.array([[0.4,0,-0.3]])
tens = torch.tensor(weight_array,dtype=torch.float32)
bias1 = torch.tensor(bias_array,dtype=torch.float32)
fn.lay1.weight = nn.Parameter(tens)
fn.lay1.bias = nn.Parameter(bias1)
