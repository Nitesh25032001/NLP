class PerceptronStack(nn.Module):
  def __init__(self):
    super().__init__()
    self.lay1 = nn.Linear(4,3,bias = True)
    self.lay2 = nn.Linear(3,2,bias = True)
    self.act1 = nn.Sigmoid()
    self.act2 = nn.Softmax(dim = -1)
  def forward(self,x):
    out = x
    out = self.lay1(out)
    out = self.act1(out)
    out = self.lay2(out)
    out = self.act2(out)
    return out
