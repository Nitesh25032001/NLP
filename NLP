import re

def segment_sentences(text):
    text = re.sub(r'\b(Dr|Mr|Mrs|Ms|Prof|M\.Sc|Ph\.D)\.', r'\1<ABBR>', text)
    text = re.sub(r'(\d)\.(\d)', r'\1<DECIMAL>\2', text)
    sentences = re.split(r'\.(?=\s+[A-Z])', text)
    sentences = [s.replace('<ABBR>', '.').replace('<DECIMAL>', '.') for s in sentences if s.strip()]
    return sentences

sample_text = "He scored 9.69 in his M.Sc. exams. Dr. Nitesh completed his Ph.D. in 2023. He is doing good in life now."

sentences = segment_sentences(sample_text)
for s in sentences:
    print(s)
print("No of sentences:", len(sentences))


